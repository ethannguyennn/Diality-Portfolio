#################### MACROS ####################
__lenVersionStr = 9
__lenEndVersionStr = 14

# matches the revision number as a decimal number
regexRevisionPattern = '[0-9]+\.[0-9]+'
# matches the date and surrounding parentheses
regexDatePattern = '[0-9]+/[0-9]+/[0-9]+'

# doc-path item number regular expression
regexDocPathItemNoPattern = r"[0-9]+"

# doc-path item number with revision number regular expression
regexDocPathRevOnItemNoPattern = r"[0-9]+-[0-9]+"

# doc-path with rev + whitespace + rev-number at end of file-name regular expression
regexDocPathRevWhitespacePattern = r"[A-Za-z]+\s[0-9]+"

# doc-path with rev + rev-number at end of file-name regular expression
regexDocPathRev = r"[A-Za-z]+[0-9]+"

